<section class="w-full py-8">
  <div class="mx-auto max-w-6xl px-4">
    {title && (
      <h2 class="text-3xl md:text-4xl font-semibold text-center mb-6 text-foreground">{title}</h2>
    )}

    <div class="grid grid-cols-1 md:grid-cols-6 gap-6 max-w-5xl mx-auto">
      {
        skills.map((skill, index) => (
          <div
            class:list={[
              "card-surface p-6 group transition-transform duration-200 hover:-translate-y-1 hover:elevate-lg",
              // Logic: 
              // 1. If it's the very last item, span all 6 columns (100%).
              // 2. If it's one of the first two, span 3 columns (50%).
              // 3. Otherwise, span 2 columns (33%).
              index === skills.length - 1 
                ? "md:col-span-6" 
                : index < 2 
                  ? "md:col-span-3" 
                  : "md:col-span-2",
            ]}
          >
            <div class="flex flex-col items-center text-center">
              <div
                class="mb-4 rounded-xl size-[48px] flex items-center justify-center text-[var(--accent)] opacity-90 transition-all duration-300 will-change-transform group-hover:scale-110 group-hover:opacity-100"
                style="background: rgba(var(--accent-rgb),0.08);"
              >
                <i class={`${skill.icon} text-2xl`} />
              </div>

              <h3 class="text-xl font-semibold text-foreground mb-2">
                {skill.title}
              </h3>
              <p class="text-[color:var(--color-text-muted)] leading-relaxed max-w-prose">
                {skill.description}
              </p>
            </div>
          </div>
        ))
      }
    </div>

    {/* Carousel logic... */}
  </div>
</section>